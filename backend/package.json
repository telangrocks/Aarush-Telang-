{
  "name": "crypto-pulse-backend",
  "version": "1.0.0",
  "description": "Backend API for Crypto Pulse, running on Cloudflare Workers.",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "clean-install": "rm -rf node_modules package-lock.json && npm cache clean --force && npm install",
    "test": "vitest run src",
    "test:watch": "vitest src",
    "test:coverage": "vitest run src --coverage",
    "test:smoke": "node scripts/smoke-test.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Aarush Telang",
  "license": "UNLICENSED",
  "dependencies": {
    "hono": "^4.4.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0",
    "wrangler": "^3.63.1"
  }
}